table CG_TimeIntelligence
	lineageTag: e1a2b3c4-d5e6-7f89-ab01-cd23ef456789

	calculationGroup
		precedence: 10

		calculationItem Current = SELECTEDMEASURE()

		calculationItem MTD =
				CALCULATE (
				    SELECTEDMEASURE (),
				    DATESMTD ( DIM_DATE[DATE] )
				)

		calculationItem YTD =
				CALCULATE (
				    SELECTEDMEASURE (),
				    DATESYTD ( DIM_DATE[DATE] )
				)

		calculationItem 'Last Year' =
				CALCULATE (
				    SELECTEDMEASURE (),
				    SAMEPERIODLASTYEAR ( DIM_DATE[DATE] )
				)

		calculationItem 'YoY %' =
				VAR Curr = SELECTEDMEASURE ()
				VAR Prev =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        SAMEPERIODLASTYEAR ( DIM_DATE[DATE] )
				    )
				RETURN
				    DIVIDE ( Curr - Prev, Prev )

			formatStringDefinition = "0.00%;-0.00%;0.00%"

		calculationItem 'Rolling 12M' =
				CALCULATE (
				    SELECTEDMEASURE (),
				    DATESINPERIOD (
				        DIM_DATE[DATE],
				        LASTDATE ( DIM_DATE[DATE] ),
				        -12,
				        MONTH
				    )
				)

	column Period
		dataType: string
		lineageTag: a1b2c3d4-e5f6-7890-bcde-f12345678901
		summarizeBy: none
		sourceColumn: Name

		annotation SummarizationSetBy = User

	changedProperty = Name

	annotation PBI_ResultType = Table

