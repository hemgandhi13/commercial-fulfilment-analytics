	measure 'Late Orders (Fulfilment)' = ```
			
			CALCULATE (
			    DISTINCTCOUNT ( FACT_FULFILMENT[order_id] ),
			    FACT_FULFILMENT[late_delivery_risk] = 1
			)
			
			```
		formatString: #,0
		displayFolder: E. Fulfillment
		lineageTag: e574031a-48c1-4001-9f61-f85f96850603

	measure 'On-Time Orders (Fulfilment)' = ```
			
			CALCULATE (
			    DISTINCTCOUNT ( FACT_FULFILMENT[order_id] ),
			    FACT_FULFILMENT[late_delivery_risk] = 0
			)
			
			```
		formatString: #,0
		displayFolder: E. Fulfillment
		lineageTag: f05781cb-4699-4ed4-b923-d099da9bc6d5

	measure 'Late Delivery Rate %' = ```
			
			DIVIDE ( [Late Orders (Fulfilment)], [Fulfilment Orders] )
			
