	measure 'Late Delivery Rate % (3M Rolling)' =
			
			CALCULATE(
			    [Late Delivery Rate %],
			    DATESINPERIOD(
			        DIM_DATE[Date],
			        LASTDATE(DIM_DATE[Date]),
			        -3,
			        MONTH
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: I. Advanced
		lineageTag: 33aad4d4-870f-4d2d-aa56-bba52e8c8340

	measure 'Shipping Gap (Days)' = [Avg Shipping Days (Real)] - [Avg Shipping Days (Scheduled)]
		displayFolder: I. Advanced
		lineageTag: a31486ba-aa88-431a-80bb-e95f31e5f674

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue at Risk' = [Net Sales] * [Late Delivery Rate %]
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: I. Advanced
