		formatString: 0.00%;-0.00%;0.00%
		displayFolder: E. Fulfillment
		lineageTag: 7d96aa4b-8fb4-4028-bd2b-7d09d81b41fb

	measure 'Avg Shipping Days (Real)' = ```
			
