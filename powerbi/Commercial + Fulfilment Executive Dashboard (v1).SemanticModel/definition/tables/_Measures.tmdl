	measure 'Handling Cost (ABC)' = ([Orders] * 2.50) + ([Quantity] * 0.50)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: K. Cost-to-Serve
		lineageTag: e1a2b3c4-d5e6-7890-abcd-ef1234567890

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Freight Cost (Est)' = ```
			
			VAR BaseFreight =
			    SUMX (
			        FACT_SALES,
			        VAR ShipMode = RELATED ( DIM_CHANNEL[SHIPPING_MODE] )
			        RETURN
			        SWITCH (
			            ShipMode,
			            "Same Day",     FACT_SALES[QUANTITY] * 8,
			            "First Class",  FACT_SALES[QUANTITY] * 5,
			            "Second Class", FACT_SALES[QUANTITY] * 3,
			            FACT_SALES[QUANTITY] * 1.5
			        )
			    )
			RETURN
			BaseFreight * ( 1 + [Selected Freight Surcharge %] )
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: K. Cost-to-Serve
		lineageTag: f2b3c4d5-e6f7-8901-bcde-f01234567891

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Cost-to-Serve' = [Handling Cost (ABC)] + [Freight Cost (Est)] + [MOQ Penalty Surcharge]
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: K. Cost-to-Serve
		lineageTag: a3c4d5e6-f7a8-9012-cdef-012345678912

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'CTS % of Net Sales' = DIVIDE ( [Total Cost-to-Serve], [Net Sales] )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: K. Cost-to-Serve
		lineageTag: b4d5e6f7-a8b9-0123-defa-123456789023

	measure 'Net Commercial Margin' = [Profit] - [Total Cost-to-Serve]
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: K. Cost-to-Serve
		lineageTag: c5e6f7a8-b9c0-1234-efab-234567890134

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Net Commercial Margin %' = DIVIDE ( [Net Commercial Margin], [Net Sales] )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: K. Cost-to-Serve
		lineageTag: d6f7a8b9-c0d1-2345-fabc-345678901245

	measure 'Revenue at Risk (Late SLA)' = ```
			
			VAR LateOrderIDs =
			    CALCULATETABLE (
			        VALUES ( FACT_FULFILMENT[order_id] ),
			        FACT_FULFILMENT[LATE_DELIVERY_RISK] = 1
			    )
			RETURN
			CALCULATE ( [Net Sales], FACT_SALES[order_id] IN LateOrderIDs )
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: L. Supply Chain Risk & Trade Spend
		lineageTag: d1e2f3a4-b5c6-7890-abcd-ef0123456789

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Estimated SLA Penalty' = [Revenue at Risk (Late SLA)] * 0.03
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: L. Supply Chain Risk & Trade Spend
		lineageTag: e2f3a4b5-c6d7-8901-bcde-f01234567890

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Retailer Rebate Accrual' = [Base Retailer Rebate Accrual] + ( [Net Sales] * [Selected Rebate Shift %] )
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: L. Supply Chain Risk & Trade Spend
		lineageTag: f3a4b5c6-d7e8-9012-cdef-012345678901

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'True Net Profit (Post-Rebate)' = ```
			
			[Net Commercial Margin] - [Estimated SLA Penalty] - [Retailer Rebate Accrual]
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: L. Supply Chain Risk & Trade Spend
		lineageTag: a4b5c6d7-e8f9-0123-defa-123456789012

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Margin Waterfall Step' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Waterfall_Bridge'[Sort Order] ),
			    1, [Total Gross Sales],
			    2, -[Discount Amount],
			    3, -[Total Cost-to-Serve],
			    4, -[Estimated SLA Penalty],
			    5, -[Retailer Rebate Accrual],
			    BLANK ()
			)
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: M. Waterfall
		lineageTag: b5c6d7e8-f9a0-1234-efab-234567890123

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'MOQ Penalty Surcharge' =
			
			SUMX (
			    FACT_SALES,
			    IF (
			        FACT_SALES[QUANTITY] < [Selected MOQ Threshold] && [Selected MOQ Threshold] > 0,
			        25,
			        0
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: K. Cost-to-Serve
		lineageTag: e5f6a7b8-c9d0-4123-4efa-123456789012

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Selected MOQ Threshold' = SELECTEDVALUE ( Scenario_MOQ[MOQ_Threshold], 0 )
		formatString: 0
		displayFolder: L. Scenario Planning
		lineageTag: c3d4e5f6-a7b8-4901-2cde-f01234567890

	measure 'Selected Rebate Shift %' = SELECTEDVALUE ( Scenario_Rebate[Rebate_Shift_Pct], 0 )
		formatString: 0.00%
		displayFolder: L. Scenario Planning
		lineageTag: d4e5f6a7-b8c9-4012-3def-012345678901

	measure 'Base Retailer Rebate Accrual' = ```
			
			SWITCH (
			    TRUE (),
			    [Net Sales] > 5000000, [Net Sales] * 0.05,
			    [Net Sales] > 1000000, [Net Sales] * 0.03,
			    [Net Sales] * 0.01
			)
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: L. Supply Chain Risk & Trade Spend
		lineageTag: f6a7b8c9-d0e1-4234-5fab-234567890123

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	partition _Measures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i45WMlSKjQUA", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Dummy = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Dummy", Int64.Type}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Dummy"})
				in
				    #"Removed Columns"

	annotation PBI_ResultType = Table

