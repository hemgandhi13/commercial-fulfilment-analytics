	measure 'Active Customers' = ```
			
			DISTINCTCOUNT ( FACT_SALES[customer_id] )
			
			```
		formatString: 0
		displayFolder: H. Customer Logic
		lineageTag: d73b56f8-b418-4cfe-abe5-d16ae2a46517

	measure 'Orders per Customer' = ```
			
			DIVIDE ( [Orders], [Active Customers] )
			
			```
		formatString: 0.00
		displayFolder: H. Customer Logic
		lineageTag: b941fa61-2962-4619-819a-33d7792cb248

	measure 'New Customers' = ```
			
			VAR MinKey = MIN ( DIM_DATE[date_key] )
			VAR MaxKey = MAX ( DIM_DATE[date_key] )
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( FACT_SALES[customer_id] ),
			    DIM_CUSTOMER[First Order Date Key] >= MinKey,
			    DIM_CUSTOMER[First Order Date Key] <= MaxKey
			)
			
			```
		formatString: 0
		displayFolder: H. Customer Logic
		lineageTag: f7330a7f-b6ff-48d9-bd12-116de35a9032

	measure 'Returning Customers' = ```
			
			VAR MinKey =
			    MINX ( ALLSELECTED ( DIM_DATE ), DIM_DATE[date_key] )
			RETURN
			COALESCE (
			    CALCULATE (
			        DISTINCTCOUNT ( FACT_SALES[customer_id] ),
			        DIM_CUSTOMER[First Order Date Key] < MinKey
			    ),
			    0
			)
			
			```
		formatString: 0
		displayFolder: H. Customer Logic
		lineageTag: dd209769-9502-4331-9068-86330bc3eca8

	measure 'Returning Customer %' = ```
			
			DIVIDE ( [Returning Customers], [Active Customers], 0 )
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: H. Customer Logic
		lineageTag: 9d3d6787-f7bb-4771-90e3-3dce92a96d1c

	measure '08 Customer Retention' = ```
			
			"Customer Retention — " & 
			IF(
			    HASONEVALUE(DIM_CHANNEL[Market]), 
			    VALUES(DIM_CHANNEL[Market]), 
			    "All Markets"
			)
			```
		lineageTag: a959c5e2-5942-4101-8a0b-6d83a5f2ac75

	measure 'Cohort Size (All Time)' = ```
			
			CALCULATE (
			    DISTINCTCOUNT ( DIM_CUSTOMER[customer_id] ),
			    REMOVEFILTERS ( DIM_DATE )
			)
			
			```
		formatString: 0
		displayFolder: I. Advanced
		lineageTag: 9d86b59c-3eac-4c01-b4f7-ba54703f1aff

	measure 'Cohort Retained Customers (Selected Period)' = ```
			
			VAR ActivityMinYM =
			    VALUE ( MIN ( DIM_DATE[YearMonthSort] ) )
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( FACT_SALES[customer_id] ),
			    FILTER (
			        ALL ( DIM_CUSTOMER ),
			        DIM_CUSTOMER[First Purchase YearMonthSort] < ActivityMinYM
			    )
			)
			
			```
		formatString: 0
		displayFolder: H. Customer Logic
		lineageTag: a0d8cb81-4f29-4795-abd0-bc744483cbf6

	measure 'Cohort Retention % (Post-Acquisition)' = ```
			
			DIVIDE (
			    [Cohort Retained Customers (Selected Period)],
			    [Cohort Size (All Time)]
			)
			
			```
		displayFolder: H. Customer Logic
		lineageTag: c359e1ff-533f-4dae-a4fc-e965cddba391

		annotation PBI_FormatHint = {"isGeneralNumber":true}

