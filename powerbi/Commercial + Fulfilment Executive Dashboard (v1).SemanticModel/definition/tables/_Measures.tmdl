		lineageTag: 126e47e5-88d4-49c8-a4e9-190dd821d587

	measure 'Avg Late Days (Late Orders Only)' = ```
			
			CALCULATE (
			    AVERAGE ( FACT_FULFILMENT[is_late_by_days] ),
			    FACT_FULFILMENT[late_delivery_risk] = 1
			)
			
			```
		formatString: 0.0
		displayFolder: F. Op Severity
		lineageTag: 4a898264-7784-4c87-9c58-51bc57785e6f

	measure '% Orders Late 3+ Days' = ```
			
			VAR Late3 =
			    CALCULATE (
			        DISTINCTCOUNT ( FACT_FULFILMENT[order_id] ),
			        FACT_FULFILMENT[is_late_by_days] >= 3
			    )
			RETURN
			DIVIDE ( Late3, [Fulfilment Orders] )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: F. Op Severity
		lineageTag: 0022edc2-b2f5-4144-843d-fa06e8451401

	measure 'Late Delivery Rate % (Ship Date)' = ```
			
			CALCULATE (
			    [Late Delivery Rate %],
			    USERELATIONSHIP ( DIM_DATE[date_key], FACT_FULFILMENT[ship_date_key] )
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: G. Ship Date Logic
		lineageTag: 3c978534-d29c-40d1-98af-fad7084ad79b

	measure 'Fulfilment Orders (Ship Date)' = ```
			
			CALCULATE (
			    [Fulfilment Orders],
			    USERELATIONSHIP ( DIM_DATE[date_key], FACT_FULFILMENT[ship_date_key] )
			)
			
			```
		formatString: #,0
		displayFolder: G. Ship Date Logic
		lineageTag: b7ede1f4-a74a-43c4-a932-e2f18e69a548

	measure 'Repeat Customers' = ```
			
			VAR T =
			    SUMMARIZE (
			        FACT_SALES,
			        FACT_SALES[customer_id],
			        "OrderCount", DISTINCTCOUNT ( FACT_SALES[order_id] )
			    )
			RETURN
			COUNTROWS ( FILTER ( T, [OrderCount] >= 2 ) )
			
			```
		formatString: #,0
		displayFolder: H. Customer Logic
		lineageTag: 7ea3c2be-74cf-4c46-bb51-0d01e164676c

	measure 'Repeat Purchase Rate %' = ```
			
			DIVIDE ( [Repeat Customers], [Active Customers] )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: H. Customer Logic
		lineageTag: 7e6edf04-9eb9-41cc-9bb0-d169a31c6877

	measure 'Net Sales % of Total' = ```
			
			DIVIDE (
			    [Net Sales],
			    CALCULATE ( [Net Sales], ALL ( DIM_PRODUCT ) )
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: I. Advanced
		lineageTag: f5f98f02-f801-4dc0-afb0-09402249feec

	measure 'Product Rank (Net Sales)' = ```
			
