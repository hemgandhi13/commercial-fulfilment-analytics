# --- Large/raw datasets (keep out of Git) ---
data/DataCoSupplyChainDataset.csv
data/DescriptionDataCoSupplyChain.csv
data/archive.zip
data/tokenized_access_logs.csv

# Ignore any future large CSV/zip dropped into /data
data/*.csv
data/*.zip

# Keep small curated samples
!data/sample/**

# Compressed files
*.gz

# --- Power BI binary files (ignore; track PBIR folder format instead) ---
# Keep .pbip project index — it's human-readable JSON and should be committed
*.pbix
*.pbit
*.pbiviz

# --- Local working folders (never commit) ---
powerbi/Docs/
powerbi/PBIX/

# --- Power BI local/cache files (nested anywhere in the tree) ---
**/.pbi/localSettings.json
**/.pbi/cache.abf
**/.pbi/editorSettings.json

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Office temp/lock files ---
~$*
